 fn in_targets(path: &str, targets: &[String]) -> bool {
     targets.is_empty()
         || targets.iter().any(|target| {
             let normalized = target.trim_end_matches('/');
             normalized == "." || path == normalized || path.starts_with(&format!("{normalized}/"))
         })
