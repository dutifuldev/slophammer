{
  "name": "slophammer-ts",
  "version": "0.1.1",
  "description": "TypeScript implementation of the Slophammer repository quality checker.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dutifuldev/slophammer.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/dutifuldev/slophammer/issues"
  },
  "homepage": "https://github.com/dutifuldev/slophammer#readme",
  "keywords": [
    "slophammer",
    "quality",
    "repository",
    "typescript",
    "cli",
    "agents"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/src/**",
    "README.md"
  ],
  "bin": {
    "slophammer-ts": "dist/src/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "dry": "node dist/src/cli/main.js dry ..",
    "bin-check": "node dist/scripts/check-package-bin.js",
    "mutate": "stryker run",
    "self-check": "node dist/src/cli/main.js check ..",
    "verify:equivalence": "vitest run tests/equivalence.test.ts",
    "check": "npm run format && npm run lint && npm run typecheck && npm test && npm run coverage && npm run build && npm run bin-check && npm run dry && npm run self-check && npm run verify:equivalence"
  },
  "dependencies": {
    "typescript": "^5.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
