{
  "name": "@dutifuldev/slophammer-ts",
  "version": "0.0.0",
  "type": "module",
  "files": [
    "dist/src/**",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "slophammer": "./dist/src/cli/main.js",
    "slophammer-ts": "./dist/src/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "dry": "node dist/src/cli/main.js dry ..",
    "bin-check": "node dist/scripts/check-package-bin.js",
    "mutate": "stryker run",
    "self-check": "node dist/src/cli/main.js check ..",
    "verify:equivalence": "vitest run tests/equivalence.test.ts",
    "check": "npm run format && npm run lint && npm run typecheck && npm test && npm run coverage && npm run build && npm run bin-check && npm run dry && npm run self-check && npm run verify:equivalence"
  },
  "dependencies": {
    "typescript": "^5.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
